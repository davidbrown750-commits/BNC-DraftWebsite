    position: absolute;
    top: 26px;
    right: 26px;
    background: var(--bnc-white);
    border: 1px solid var(--bnc-sky-blue);
    border-radius: 6px;
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    z-index: 10;
