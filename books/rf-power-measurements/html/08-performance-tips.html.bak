    padding: 88px 36px 64px 36px;
    border-bottom: 6px solid var(--bnc-sky-blue);
    overflow: hidden;
  }
  header.cover::before {
    content: "";
    position: absolute; inset: 0;
    background:
      linear-gradient(120deg, transparent 0 28%, rgba(127,219,255,0.05) 28% 60%, transparent 60%),
      linear-gradient(155deg, transparent 0 40%, rgba(0,180,255,0.03) 40% 75%, transparent 75%);
    pointer-events: none;
  }
  header.cover .series {
    font-family: "Helvetica Neue", "Arial Black", Arial, sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: var(--bnc-light-cyan);
    font-size: 14px;
    margin: 0 0 16px 0;
    position: relative;
  }
  header.cover h1 {
    font-family: "Helvetica Neue", "Arial Black", Arial, sans-serif;
    font-weight: 900;
    font-size: 3rem;
    line-height: 1.05;
    color: var(--bnc-white);
    margin: 0 0 8px 0;
    letter-spacing: -0.5px;
    position: relative;
    text-transform: uppercase;
  }
  header.cover h1 .small { display: block; font-size: 1.1rem; font-weight: 500; letter-spacing: 2px; color: var(--bnc-light-cyan); margin-bottom: 12px; text-transform: none; font-style: italic; font-family: Georgia, serif; }
  header.cover .byline {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 1.1rem;
    margin-top: 26px;
    color: var(--bnc-white);
    opacity: 0.92;
    position: relative;
  }
  header.cover .byline strong { font-weight: 700; }
  header.cover .edition {
    margin-top: 28px;
    font-family: Georgia, serif;
    font-style: italic;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    font-size: 13px;
    color: var(--bnc-bright-cyan);
