{
  "rewrites": [
    {
      "source": "/",
      "destination": "/home.html"
    }
  ],
  "redirects": [
    {
      "source": "/management/",
      "destination": "/management.html",
      "permanent": true
    },
    {
      "source": "/about/",
      "destination": "/our-history.html",
      "permanent": true
    },
    {
      "source": "/faq/",
      "destination": "/faq.html",
      "permanent": true
    },
    {
      "source": "/contact/",
      "destination": "/contact.html",
      "permanent": true
    },
    {
      "source": "/get-quote/",
      "destination": "/get-quote.html",
      "permanent": true
    },
    {
      "source": "/obsolete-products/",
      "destination": "/obsolete-products.html",
      "permanent": true
    },
    {
      "source": "/products/arbitrary-waveform-generator/",
      "destination": "/awg-home.html",
      "permanent": true
    },
    {
      "source": "/products/custom-scintillation-detectors/",
      "destination": "/scintiq-home.html",
      "permanent": true
    },
    {
      "source": "/v6-spectrum-analyzers",
      "destination": "/rtsa-home.html",
      "permanent": true
    },
    {
      "source": "/v6-spectrum-analyzers/",
      "destination": "/rtsa-home.html",
      "permanent": true
    },
    {
      "source": "/index-bold.html",
      "destination": "/rtsa-home.html",
      "permanent": true
    },
    {
      "source": "/downloads",
      "destination": "/docs/software-drivers.html",
      "permanent": true
    },
    {
      "source": "/downloads/",
      "destination": "/docs/software-drivers.html",
      "permanent": true
    },
    {
      "source": "/download/:path*",
      "destination": "/docs/software-drivers.html",
      "permanent": true
    },
    {
      "source": "/download/:id/",
      "destination": "/docs/software-drivers.html",
      "permanent": true
    },
    {
      "source": "/model-865",
      "destination": "/docs/bnc-model-865b-datasheet.html",
      "permanent": true
    },
    {
      "source": "/model-865/",
      "destination": "/docs/bnc-model-865b-datasheet.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "draft.berkeleynucleonics.com" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "bnc-draft-website.vercel.app" }],
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ]
}